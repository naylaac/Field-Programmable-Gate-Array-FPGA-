library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
entity mux21 is
Port (D0 : in STD_LOGIC;
D1 : in STD_LOGIC;
Sel : in STD_LOGIC;
Y : out STD_LOGIC);
end mux21;

architecture Dataflow of mux21 is
begin
-- Y bernilai D1 jika Selector '1', jika tidak Y bernilai D0
Y <= D1 when (Sel = '1') else D0;
end Dataflow;
