library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
entity tb_full_adder is
end tb_full_adder;
architecture behavior of tb_full_adder is
component full_adder
Port ( A, B, Cin : in STD_LOGIC;
Sum, Cout : out STD_LOGIC);
end component;
signal A, B, Cin, Sum, Cout : STD_LOGIC := '0';
begin
UUT: full_adder port map (A => A, B => B, Cin => Cin,
Sum => Sum, Cout => Cout);
stim_proc: process
begin
A<='0'; B<='0'; Cin<='0'; wait for 100 ns;
A<='0'; B<='1'; Cin<='0'; wait for 100 ns;
A<='1'; B<='1'; Cin<='0'; wait for 100 ns;
A<='1'; B<='1'; Cin<='1'; wait for 100 ns;
wait;
end process;
end behavior;
